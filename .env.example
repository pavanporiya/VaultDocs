# =============================================================================
# VaultDocs Environment Configuration
# =============================================================================
# Copy this file:
#
#   cp .env.example .env
#
# Then update the values below before running the application.
#
# =============================================================================


# =============================================================================
# Application
# =============================================================================

APP_NAME=VaultDocs
APP_ENV=development
DEBUG=true
APP_PORT=8000


# =============================================================================
# Security
# =============================================================================
# Generate a secure key:
#
# python -c "import secrets; print(secrets.token_urlsafe(32))"
#

SECRET_KEY=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_KEY

ACCESS_TOKEN_EXPIRE_MINUTES=60


# =============================================================================
# Database
# =============================================================================

DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=VaultDocs
DATABASE_USER=VaultDocs_user
DATABASE_PASSWORD=change-me-in-production

DATABASE_URL=postgresql+asyncpg://${DATABASE_USER}:${DATABASE_PASSWORD}@${DATABASE_HOST}:${DATABASE_PORT}/${DATABASE_NAME}


# =============================================================================
# Logging
# =============================================================================

LOG_LEVEL=INFO


# =============================================================================
# CORS
# =============================================================================

BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000


# =============================================================================
# File Upload
# =============================================================================

UPLOAD_DIR=uploads

MAX_UPLOAD_SIZE_MB=25


# =============================================================================
# Docker
# =============================================================================
# Docker Compose automatically overrides DATABASE_HOST=db
# No changes are required when using docker-compose.
# =============================================================================