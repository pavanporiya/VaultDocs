# =============================================================================
# VaultDocs — Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# =============================================================================

# --------------- Application ---------------
APP_NAME=VaultDocs
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
APP_SECRET_KEY=change-me-in-production

# --------------- Database ---------------
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=VaultDocs
DATABASE_USER=VaultDocs_user
DATABASE_PASSWORD=change-me-in-production
DATABASE_URL=postgresql+asyncpg://${DATABASE_USER}:${DATABASE_PASSWORD}@${DATABASE_HOST}:${DATABASE_PORT}/${DATABASE_NAME}

# --------------- Redis (Cache) ---------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# --------------- Storage ---------------
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./uploads
# STORAGE_S3_BUCKET=
# STORAGE_S3_REGION=
# STORAGE_S3_ACCESS_KEY=
# STORAGE_S3_SECRET_KEY=

# --------------- Email ---------------
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@VaultDocs.local

# --------------- Authentication ---------------
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --------------- CORS ---------------
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# --------------- Logging ---------------
LOG_LEVEL=DEBUG
LOG_FORMAT=json
