__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
*.whl
.eggs/

# --------------- Virtual Environments ---------------
.venv/
venv/
ENV/
env/

# --------------- uv ---------------
.uv/

# --------------- IDE ---------------
.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath
.settings/

# --------------- Environment Variables ---------------
.env
.env.local
.env.*.local

# --------------- Testing ---------------
.coverage
htmlcov/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --------------- Docker ---------------
docker-compose.override.yml

# --------------- OS ---------------
.DS_Store
Thumbs.db
desktop.ini

# --------------- Logs ---------------
*.log
logs/

# --------------- Database ---------------
*.db
*.sqlite3

# --------------- Node (Frontend) ---------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.next/
out/

# --------------- Misc ---------------
*.bak
*.tmp
*.temp
